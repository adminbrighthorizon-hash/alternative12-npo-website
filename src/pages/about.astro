---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';
---

<Layout
	title="Company Overview | COPAK GENERAL TRADING (CGT)"
	description="Discover COPAK GENERAL TRADING's company overview, commitments, vision, mission, and values as a leading provider of industrial solutions in DR Congo."
>
	<SiteShell activePath="/about">
		<main>
			<!-- Page Hero -->
			<section class="page-hero">
				<div class="hero-bg">
					<img src={site.gallery[5].src} alt={site.gallery[5].alt} />
					<div class="hero-overlay"></div>
				</div>
				<div class="hero-content section">
					<p class="hero-eyebrow">Company Overview</p>
					<h1>Leading industrial expertise at the service of your success.</h1>
					<p class="hero-sub">{site.mission}</p>
				</div>
			</section>

			<!-- Company Overview -->
			<section class="content-section">
				<div class="section">
					<div class="two-col">
						<div class="col-text">
							<p class="eyebrow">Who We Are</p>
							<h2>COPAK GENERAL TRADING (CGT) is a leading Congolese provider of complete industrial solutions.</h2>
							<p>Since its inception, CGT has focused on delivering high-quality services from industrial equipment supply to installation and maintenance. Our expertise spans electrical, mechanical, instrumentation, electrowinning, conveyor accessories, pumps, valves, filters, reagents, chemicals, laboratory equipment, PPE, and critical equipment spares.</p>
							<p>With a team of seasoned experts, we provide customized solutions tailored to each client's specific needs, ensuring quality outcomes and long-term value.</p>
						</div>
						<div class="col-image">
							<img src={site.gallery[1].src} alt={site.gallery[1].alt} loading="lazy" decoding="async" />
						</div>
					</div>
				</div>
			</section>

			<!-- Core Values -->
			<section class="values-section">
				<div class="section">
					<div class="section-heading">
						<p class="eyebrow">Our Values</p>
						<h2>The foundation of our success and client trust.</h2>
					</div>
					<div class="values-grid">
						<article class="value-card">
							<h3>Excellence</h3>
							<p>We are committed to the highest quality products and services, aligned with strict standards and client expectations.</p>
						</article>
						<article class="value-card">
							<h3>Innovation</h3>
							<p>We continuously pursue better solutions to industrial challenges and evolving market needs.</p>
						</article>
						<article class="value-card">
							<h3>Adaptability</h3>
							<p>We remain flexible and responsive to the unique requirements of every project and client environment.</p>
						</article>
						<article class="value-card">
							<h3>Commitment</h3>
							<p>We build long-term, trust-based partnerships and remain a reliable, responsive industrial partner.</p>
						</article>
					</div>
				</div>
			</section>

			<!-- Vision and Mission -->
			<section class="process-section">
				<div class="section">
					<div class="section-heading">
						<p class="eyebrow">Vision and Mission</p>
						<h2>Clear direction for sustainable industrial value.</h2>
					</div>
					<div class="process-grid">
						<article class="process-card">
							<span class="process-num">01</span>
							<h3>Vision</h3>
							<p>To become the undisputed leader in industrial solutions in the Democratic Republic of Congo.</p>
						</article>
						<article class="process-card">
							<span class="process-num">02</span>
							<h3>Mission</h3>
							<p>Deliver comprehensive and innovative solutions with exceptional after-sales service and trusted support.</p>
						</article>
						<article class="process-card">
							<span class="process-num">03</span>
							<h3>Commitment Since 2023</h3>
							<p>Tailored solutions, quality-focused execution, and consistent adaptability for every engagement.</p>
						</article>
						<article class="process-card">
							<span class="process-num">04</span>
							<h3>Client Relationship</h3>
							<p>Long-term partnerships built on reliability, responsiveness, and measurable delivery quality.</p>
						</article>
					</div>
				</div>
			</section>

			<!-- Teams and Partners -->
			<section class="team-section">
				<div class="section">
					<div class="section-heading">
						<p class="eyebrow">Our Teams and Partners</p>
						<h2>Qualified professionals backed by a trusted partner network.</h2>
					</div>
					<div class="team-grid">
						{site.team.map((member) => (
							<article class="team-card">
								<div class="team-avatar">{member.name.split(' ').map(n => n[0]).join('')}</div>
								<h3>{member.name}</h3>
								<span class="team-role">{member.role}</span>
								<p>{member.bio}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<!-- Partnerships Section -->
			<section class="photos-section">
				<div class="section">
					<div class="photos-grid">
						{site.gallery.slice(0, 3).map((item) => (
							<figure class="photo-card">
								<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
								<figcaption>
									<strong>{item.title}</strong>
									<span>{item.description}</span>
								</figcaption>
							</figure>
						))}
					</div>
				</div>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.page-hero {
		position: relative;
		min-height: 50vh;
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
	}

	.hero-bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to right, rgba(26, 58, 42, 0.9) 0%, rgba(26, 58, 42, 0.5) 100%);
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding: 5rem 0;
		max-width: 640px;
		color: #fff;
	}

	.hero-eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.75);
		margin: 0 0 1rem;
	}

	.hero-content h1 {
		font-size: clamp(2rem, 4vw, 3.2rem);
		margin-bottom: 1rem;
		color: #fff;
	}

	.hero-sub {
		font-size: 1.1rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.85);
		margin: 0;
	}

	.content-section {
		padding: 5rem 0;
	}

	.two-col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.col-text h2 {
		font-size: clamp(1.6rem, 3vw, 2.2rem);
		margin-bottom: 1.25rem;
	}

	.col-text p {
		color: var(--text-light);
		line-height: 1.75;
		margin: 0 0 1rem;
	}

	.col-image {
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-lg);
	}

	.col-image img {
		display: block;
		width: 100%;
		height: 380px;
		object-fit: cover;
	}

	.values-section {
		padding: 5rem 0;
		background: var(--surface);
	}

	.values-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	.value-card {
		padding: 2rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		transition: all 0.25s ease;
	}

	.value-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.value-card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.6rem;
		color: var(--primary);
	}

	.value-card p {
		color: var(--text-light);
		line-height: 1.65;
		margin: 0;
		font-size: 0.95rem;
	}

	.process-section {
		padding: 5rem 0;
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	.process-card {
		padding: 2rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
	}

	.process-num {
		display: inline-block;
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--primary-light);
		letter-spacing: 0.08em;
		margin-bottom: 1rem;
	}

	.process-card h3 {
		font-size: 1.3rem;
		margin-bottom: 0.6rem;
	}

	.process-card p {
		color: var(--text-light);
		line-height: 1.65;
		margin: 0;
	}

	.team-section {
		padding: 5rem 0;
		background: var(--surface);
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.team-card {
		text-align: center;
		padding: 2.5rem 2rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
	}

	.team-avatar {
		width: 4rem;
		height: 4rem;
		margin: 0 auto 1.25rem;
		border-radius: 50%;
		background: var(--primary);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 1.1rem;
	}

	.team-card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.25rem;
	}

	.team-role {
		display: block;
		font-size: 0.85rem;
		color: var(--primary-light);
		font-weight: 500;
		margin-bottom: 1rem;
	}

	.team-card p {
		color: var(--text-light);
		line-height: 1.65;
		font-size: 0.95rem;
		margin: 0;
	}

	.photos-section {
		padding: 5rem 0;
	}

	.photos-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.photo-card {
		margin: 0;
		position: relative;
		border-radius: var(--radius-md);
		overflow: hidden;
	}

	.photo-card img {
		display: block;
		width: 100%;
		height: 260px;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.photo-card:hover img {
		transform: scale(1.05);
	}

	.photo-card figcaption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 2.5rem 1.25rem 1.25rem;
		background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
		color: #fff;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.photo-card:hover figcaption {
		opacity: 1;
	}

	.photo-card figcaption strong {
		display: block;
		margin-bottom: 0.25rem;
	}

	.photo-card figcaption span {
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.8);
	}

	@media (max-width: 960px) {
		.two-col,
		.values-grid,
		.process-grid {
			grid-template-columns: 1fr 1fr;
		}

		.team-grid,
		.photos-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.two-col,
		.values-grid,
		.process-grid {
			grid-template-columns: 1fr;
		}

		.page-hero {
			min-height: 40vh;
		}
	}
</style>