---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const profileBackground = `${base}/photos/hero-industrial.jpg`;
---

<Layout title={`Company Profile | ${site.name}`} description="Company profile, commitments, mission, vision, and values of COPAK GENERAL TRADING.">
	<SiteShell activePath="/about">
		<main class="section profile">
			<section class="panel intro" style={`--profile-bg: url('${profileBackground}')`}>
				<p class="eyebrow">Summary</p>
				<h1>Company Profile</h1>
				<p>
					{site.name} is a leading Congolese provider of complete industrial solutions. Since 2023, the company has
					committed to quality delivery in supply, installation, and maintenance for mission-critical industrial operations.
				</p>
			</section>

			<section class="grid two section-gap">
				<article class="panel block">
					<h2>Our Commitments</h2>
					<ul>
						{site.commitments.map((item) => <li>{item}</li>)}
					</ul>
				</article>
				<article class="panel block">
					<h2>Our Teams & Partners</h2>
					<p>{site.teamSummary}</p>
					<p>{site.partnersSummary}</p>
				</article>
			</section>

			<section class="grid two section-gap">
				<article class="panel block">
					<h2>Vision</h2>
					<p>{site.vision}</p>
				</article>
				<article class="panel block">
					<h2>Mission</h2>
					<p>{site.mission}</p>
				</article>
			</section>

			<section class="section-gap">
				<div class="panel block">
					<h2>Our Values</h2>
					<div class="value-grid">
						{site.values.map((value) => (
							<article class="value-card">
								<h3>{value.title}</h3>
								<p>{value.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.profile {
		padding: 2rem 0;
	}

	.intro {
		position: relative;
		overflow: hidden;
		padding: 1.4rem;
	}

	.intro::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(100deg, rgba(15, 17, 19, 0.9) 0%, rgba(15, 17, 19, 0.72) 48%, rgba(15, 17, 19, 0.85) 100%),
			var(--profile-bg) center/cover no-repeat;
		opacity: 0.92;
		z-index: 0;
		animation: introPan 18s ease-in-out infinite alternate;
		transform-origin: center;
	}

	.intro > * {
		position: relative;
		z-index: 1;
	}

	@keyframes introPan {
		0% {
			transform: scale(1.05) translate3d(0, 0, 0);
		}
		100% {
			transform: scale(1.11) translate3d(-2%, -1%, 0);
		}
	}

	.intro h1 {
		font-size: clamp(1.9rem, 4vw, 3rem);
		margin: 0.4rem 0 0.8rem;
	}

	.intro p,
	.block p,
	.block li,
	.value-card p {
		color: var(--muted);
	}

	.section-gap {
		padding-top: 1.1rem;
	}

	.grid.two {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.block {
		padding: 1.2rem;
	}

	.block ul {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.45rem;
	}

	.value-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.7rem;
		margin-top: 0.8rem;
	}

	.value-card {
		padding: 0.9rem;
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		background: var(--surface-soft);
	}

	.value-card h3 {
		font-size: 1rem;
		margin-bottom: 0.35rem;
	}

	@media (max-width: 980px) {
		.grid.two {
			grid-template-columns: 1fr;
		}

		.value-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.value-grid {
			grid-template-columns: 1fr;
		}
	}
</style>