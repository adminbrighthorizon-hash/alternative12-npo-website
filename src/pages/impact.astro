---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const strengthBackground = `${base}/photos/company-profile/our-strength-bg.jpg`;
---

<Layout title={`Our Strength | ${site.name}`} description="Our strengths, teams, and strategic partnerships.">
	<SiteShell activePath="/impact">
		<main class="section strengths-page">
			<section class="panel intro" style={`--strength-bg: url('${strengthBackground}')`}>
				<p class="eyebrow">Our Strength</p>
				<h1>Reliable Execution Backed by Expertise</h1>
				<p>
					We combine technical depth, responsive coordination, and strategic partnerships to deliver high-value outcomes
					for industrial clients in the DRC and across the region.
				</p>
			</section>

			<section class="grid two section-gap">
				<article class="panel block">
					<h2>Teams</h2>
					<p>{site.teamSummary}</p>
				</article>
				<article class="panel block">
					<h2>Partners</h2>
					<p>{site.partnersSummary}</p>
				</article>
			</section>

			<section class="section-gap values-panel panel">
				<h2>What Makes Us Trusted</h2>
				<div class="value-grid">
					{site.values.map((value) => (
						<article class="value-card">
							<h3>{value.title}</h3>
							<p>{value.description}</p>
						</article>
					))}
				</div>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.strengths-page {
		padding: 2rem 0;
	}

	.intro,
	.block,
	.values-panel {
		padding: 1.2rem;
	}

	.intro {
		position: relative;
		overflow: hidden;
	}

	.intro::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(100deg, rgba(15, 17, 19, 0.9) 0%, rgba(15, 17, 19, 0.72) 48%, rgba(15, 17, 19, 0.86) 100%),
			var(--strength-bg) center/cover no-repeat;
		opacity: 0.93;
		z-index: 0;
		animation: introPan 18s ease-in-out infinite alternate;
		transform-origin: center;
	}

	.intro > * {
		position: relative;
		z-index: 1;
	}

	@keyframes introPan {
		0% {
			transform: scale(1.05) translate3d(0, 0, 0);
		}
		100% {
			transform: scale(1.11) translate3d(-2%, -1%, 0);
		}
	}

	.intro h1 {
		font-size: clamp(1.8rem, 3.8vw, 2.7rem);
		margin: 0.4rem 0 0.8rem;
	}

	.intro p,
	.block p,
	.value-card p {
		color: var(--muted);
	}

	.grid.two {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.section-gap {
		padding-top: 1rem;
	}

	.value-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.7rem;
		margin-top: 0.8rem;
	}

	.value-card {
		padding: 0.9rem;
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		background: var(--surface-soft);
	}

	.value-card h3 {
		margin-bottom: 0.35rem;
		font-size: 1rem;
	}

	@media (max-width: 980px) {
		.grid.two {
			grid-template-columns: 1fr;
		}

		.value-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.value-grid {
			grid-template-columns: 1fr;
		}
	}
</style>