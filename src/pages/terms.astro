---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';
---

<Layout title={`Terms of Use | ${site.name}`} description="Terms of use for the Alternative 12 website.">
	<SiteShell activePath="/terms">
		<main class="section page">
			<section class="panel content">
				<h1>Terms of Use</h1>
				<p class="updated">Last updated: March 2026</p>

				<h2>Acceptance of Terms</h2>
				<p>By accessing and using the Alternative 12 website, you agree to these terms of use. If you do not agree, please do not use this website.</p>

				<h2>Use of Content</h2>
				<p>All text, images, and materials on this website are the property of Alternative 12 or used with permission. You may share our content for non-commercial purposes with proper attribution. Reproduction for commercial use without written consent is prohibited.</p>

				<h2>Donations</h2>
				<p>Donations made through this website are voluntary contributions to support Alternative 12's programs. All donations are used in accordance with our stated mission. Refund requests should be directed to <a href={`mailto:${site.contacts.general}`}>{site.contacts.general}</a>.</p>

				<h2>Accuracy of Information</h2>
				<p>We make every effort to ensure the information on this website is accurate and up to date. However, we do not guarantee completeness or accuracy and reserve the right to update content without notice.</p>

				<h2>External Links</h2>
				<p>This website may contain links to external sites. Alternative 12 is not responsible for the content or privacy practices of those sites.</p>

				<h2>Limitation of Liability</h2>
				<p>Alternative 12 provides this website on an "as is" basis. We are not liable for any damages arising from your use of this website or inability to access it.</p>

				<h2>Changes to These Terms</h2>
				<p>We may update these terms from time to time. Continued use of the website after changes constitutes acceptance of the revised terms.</p>

				<h2>Contact</h2>
				<p>Questions about these terms can be sent to <a href={`mailto:${site.contacts.general}`}>{site.contacts.general}</a>.</p>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.page {
		padding: 2rem 0;
	}

	.content {
		padding: 1.5rem;
		max-width: 48rem;
		margin: 0 auto;
	}

	.content h1 {
		font-family: var(--font-serif, 'Playfair Display', serif);
		color: var(--primary, #173f2d);
		margin-bottom: 0.25rem;
	}

	.updated {
		color: var(--muted, #666);
		font-size: 0.85rem;
		margin-bottom: 1.5rem;
	}

	.content h2 {
		color: var(--primary, #173f2d);
		font-size: 1.15rem;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.content p,
	.content li {
		color: var(--text, #333);
		line-height: 1.7;
	}

	.content a {
		color: var(--accent, #d4a437);
	}
</style>
