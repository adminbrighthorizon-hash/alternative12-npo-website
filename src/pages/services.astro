---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---


<Layout title={`Services | ${site.name}`} description="Legacy route maintained for program and support service access.">
	<SiteShell activePath="/services">
		<main class="section services-page">
			<section class="panel intro">
				<p class="eyebrow">Legacy Route</p>
				<h1>Services Now Live Under Our Programs</h1>
				<p>
					This page is preserved for older links. Alternative 12 now presents its work through program areas focused on
					inclusive education, rehabilitation, child protection, disability inclusion, and family support in DR Congo and
					South Africa.
				</p>
				<div class="intro-actions">
					<a class="quote-button" href={`${base}/programs`}>View Our Programs</a>
					<a class="secondary-link" href={`${base}/contact`}>Contact Our Team</a>
				</div>
			</section>

			<section class="cards section-gap">
				{site.programs.map((program) => (
					<article class="panel group-card">
						<span class="program-id">{program.id}</span>
						<h2>{program.title}</h2>
						<p>{program.description}</p>
					</article>
				))}
			</section>

			<section class="panel support-panel section-gap">
				<p class="eyebrow">Why Support This Work</p>
				<h2>Donor-backed, locally rooted, and focused on the most vulnerable children.</h2>
				<ul>
					{site.trustPoints.map((point) => <li>{point}</li>)}
				</ul>
				<p class="support-contact">
					Email <a href={`mailto:${site.contacts.general}`}>{site.contacts.general}</a> to discuss partnerships or support.
				</p>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.services-page {
		padding: 2rem 0;
	}

	.intro {
		padding: 1.35rem;
	}

	.intro h1 {
		font-size: clamp(1.85rem, 3.8vw, 2.8rem);
		margin: 0.4rem 0 0.8rem;
	}

	.intro-actions {
		margin-top: 1.2rem;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.85rem 1rem;
	}

	.quote-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.78rem 1.18rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #1d4b35, #2f6b4c);
		color: #f8fbf5;
		font-weight: 800;
		font-size: 0.88rem;
		letter-spacing: 0.02em;
		text-decoration: none;
		box-shadow: 0 14px 30px rgba(29, 75, 53, 0.22);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.quote-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 18px 34px rgba(29, 75, 53, 0.28);
	}

	.secondary-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.78rem 1.05rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		color: var(--primary);
		background: rgba(29, 75, 53, 0.08);
		border: 1px solid rgba(29, 75, 53, 0.14);
	}

	.secondary-link:hover {
		background: rgba(29, 75, 53, 0.14);
	}

	.intro p,
	.group-card p,
	.support-contact {
		margin: 0;
		color: var(--text-light);
	}

	.section-gap {
		padding-top: 1rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.group-card {
		padding: 1rem;
	}

	.program-id {
		display: inline-block;
		margin-bottom: 0.45rem;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--primary-light);
	}

	.group-card h2 {
		font-size: 1.12rem;
		margin-bottom: 0.55rem;
	}

	.support-panel {
		padding: 1.2rem;
	}

	.support-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.4rem;
		color: var(--text-light);
	}

	.support-panel h2 {
		font-size: clamp(1.45rem, 3vw, 2rem);
		margin: 0.35rem 0 0.9rem;
	}

	@media (max-width: 980px) {
		.cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>