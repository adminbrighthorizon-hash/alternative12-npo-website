---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`Services Overview | ${site.name}`} description="Legacy route maintained for services overview.">
	<SiteShell activePath="/services">
		<main class="section page">
			<section class="panel card">
				<p class="eyebrow">Route Compatibility</p>
				<h1>Products & Services</h1>
				<p>
					This route is maintained for compatibility. View the complete and updated portfolio on our dedicated
					services page.
				</p>
				<a class="btn" href={`${base}/services`}>Open Full Services Portfolio</a>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.page {
		padding: 2rem 0;
	}

	.card {
		padding: 1.2rem;
	}

	.card p {
		color: var(--muted);
	}

	.btn {
		display: inline-block;
		text-decoration: none;
		padding: 0.58rem 0.95rem;
		border-radius: 0.65rem;
		font-size: 0.88rem;
		font-weight: 600;
		background: linear-gradient(135deg, var(--accent), var(--accent-soft));
		color: #fff;
		margin-top: 0.7rem;
	}
</style>