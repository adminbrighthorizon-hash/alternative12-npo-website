---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
	title="Contact | COPAK GENERAL TRADING (CGT)"
	description="Contact COPAK GENERAL TRADING for industrial product requests, technical services, and partnership enquiries."
>
	<SiteShell activePath="/contact">
		<main>
			<!-- Page Hero -->
			<section class="page-hero">
				<div class="hero-bg">
					<img src={site.gallery[0].src} alt={site.gallery[0].alt} />
					<div class="hero-overlay"></div>
				</div>
				<div class="hero-content section">
					<p class="hero-eyebrow">Contact Us</p>
					<h1>Get in touch for products, services, and partnership enquiries.</h1>
					<p class="hero-sub">Our team is ready to help with industrial sourcing, technical support, and project-specific requirements.</p>
				</div>
			</section>

			<!-- Business CTA -->
			<section class="donor-cta-section">
				<div class="section">
					<div class="donor-cta">
						<div class="donor-cta-text">
							<p class="eyebrow">Work With CGT</p>
							<h2>Need a reliable industrial solutions provider?</h2>
							<p>Contact us to discuss your product requirements, technical support needs, and delivery timelines.</p>
						</div>
						<a class="button button-primary" href={`mailto:${site.contacts.general}?subject=Industrial%20Quote%20Request`}>Request a Quote</a>
					</div>
				</div>
			</section>

			<!-- Contact Cards -->
			<section class="contact-section">
				<div class="section">
					<div class="contact-grid">
						<article class="contact-card">
							<h3>Partnerships</h3>
							<p>For supplier collaborations and strategic business partnerships.</p>
							<a href={`mailto:${site.contacts.partnerships}`}>{site.contacts.partnerships}</a>
						</article>
						<article class="contact-card">
							<h3>General Enquiries</h3>
							<p>For products, services, and all other business enquiries.</p>
							<a href={`mailto:${site.contacts.general}`}>{site.contacts.general}</a>
						</article>
						<article class="contact-card">
							<h3>Phone</h3>
							<p>Main contact line.</p>
							<a href={`tel:${site.contacts.phone.replace(/\s+/g, '')}`}>{site.contacts.phone}</a>
							<p style="margin-top: 0.5rem;">Secondary: <a href="tel:+27677584446">+27 67 758 4446</a></p>
						</article>
						<article class="contact-card">
							<h3>Office</h3>
							<p>{site.contacts.address}</p>
							<span class="hours">Lubumbashi, Haut-Katanga, RDC</span>
						</article>
						<article class="contact-card">
							<h3>Company Registration</h3>
							<p>RCCM: CD/LSH/RCCM/24-B-00695</p>
							<p>ID NAT: 05-S9502-N58278L</p>
							<p>NUMERO IMPOT: A2408513F</p>
							<p>ARSP: 6209253671</p>
						</article>
					</div>
				</div>
			</section>

			<!-- Map / Photo Section -->
			<section class="photo-section">
				<div class="section">
					<div class="photo-grid">
						<figure class="photo-card">
							<img src={site.gallery[1].src} alt={site.gallery[1].alt} loading="lazy" decoding="async" />
							<figcaption>Industrial products and technical support</figcaption>
						</figure>
						<figure class="photo-card">
							<img src={site.gallery[3].src} alt={site.gallery[3].alt} loading="lazy" decoding="async" />
							<figcaption>Maintenance and installation expertise</figcaption>
						</figure>
					</div>
				</div>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.page-hero {
		position: relative;
		min-height: 45vh;
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
	}

	.hero-bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to right, rgba(26, 58, 42, 0.9) 0%, rgba(26, 58, 42, 0.5) 100%);
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding: 5rem 0;
		max-width: 640px;
		color: #fff;
	}

	.hero-eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.75);
		margin: 0 0 1rem;
	}

	.hero-content h1 {
		font-size: clamp(1.8rem, 3.5vw, 2.8rem);
		margin-bottom: 1rem;
		color: #fff;
	}

	.hero-sub {
		font-size: 1.1rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.85);
		margin: 0;
	}

	.donor-cta-section {
		padding: 4rem 0;
	}

	.donor-cta {
		display: grid;
		grid-template-columns: 1.3fr 0.7fr;
		gap: 2rem;
		align-items: center;
		padding: 2.5rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
	}

	.donor-cta h2 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.donor-cta p {
		color: var(--text-light);
		line-height: 1.65;
		margin: 0;
	}

	.donor-cta .button {
		justify-self: end;
		white-space: nowrap;
	}

	.contact-section {
		padding: 0 0 5rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.contact-card {
		padding: 2rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
	}

	.contact-card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.5rem;
	}

	.contact-card p {
		color: var(--text-light);
		line-height: 1.65;
		margin: 0 0 0.75rem;
	}

	.contact-card a {
		display: inline-block;
		font-weight: 600;
		color: var(--primary);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.contact-card a:hover {
		color: var(--primary-light);
	}

	.hours {
		font-size: 0.9rem;
		color: var(--text-light);
	}

	.photo-section {
		padding: 0 0 5rem;
	}

	.photo-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.photo-card {
		margin: 0;
		border-radius: var(--radius-lg);
		overflow: hidden;
		position: relative;
	}

	.photo-card img {
		display: block;
		width: 100%;
		height: 280px;
		object-fit: cover;
	}

	.photo-card figcaption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 2rem 1.25rem 1.25rem;
		background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
		color: #fff;
		font-size: 0.9rem;
		font-weight: 500;
	}

	@media (max-width: 960px) {
		.donor-cta {
			grid-template-columns: 1fr;
		}

		.donor-cta .button {
			justify-self: start;
		}

		.contact-grid,
		.photo-grid {
			grid-template-columns: 1fr;
		}
	}
</style>