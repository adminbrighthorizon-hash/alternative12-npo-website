---
import { site } from '../data/site';

interface Props {
	activePath?: string;
}

const { activePath = '/' } = Astro.props;
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="site-shell">
	<header class="site-header">
		<div class="header-inner section">
			<a class="brand-lockup" href={`${base}/`} aria-label={site.name}>
				<img class="brand-mark" src={`${base}/a12.pic1.png`} alt="" aria-hidden="true" loading="eager" decoding="async" />
				<span class="brand-name">{site.name}</span>
			</a>

			<button class="mobile-toggle" aria-label="Toggle navigation" aria-expanded="false">
				<span class="hamburger"></span>
			</button>

			<nav class="nav-links" aria-label="Primary">
				{site.nav.map((item) => (
					<a class={item.href === activePath ? 'active' : undefined} href={`${base}${item.href}`}>{item.label}</a>
				))}
				<a class="nav-cta" href={`${base}/donate`}>Transform a Child’s Future</a>
			</nav>
		</div>
	</header>

	<slot />

	<footer class="site-footer">
		<div class="footer-inner section">
			<div class="footer-grid">
				<div class="footer-brand footer-panel">
					<p class="footer-kicker">Alternative 12</p>
					<a class="brand-lockup" href={`${base}/`} aria-label={site.name}>
						<img class="brand-mark" src={`${base}/a12.pic1.png`} alt="" aria-hidden="true" loading="lazy" decoding="async" />
						<span class="brand-name">{site.name}</span>
					</a>
					<p class="footer-mission">{site.tagline}</p>
					<div class="footer-presence" aria-label="Regional presence">
						<span>Kinshasa</span>
						<span>Lubumbashi</span>
						<span>Cape Town</span>
					</div>
					<div class="footer-actions">
						<a class="button button-primary footer-button" href={`${base}/donate`}>Donate Now</a>
						<a class="button footer-button footer-button-secondary" href={`mailto:${site.contacts.partnerships}`}>Partner With Us</a>
					</div>
				</div>

				<div class="footer-details footer-panel">
					<div class="footer-meta-grid">
						<section class="footer-col">
							<h4>Where We Work</h4>
							<p class="footer-copy">We are currently operating in DR Congo and South Africa with community-based delivery and clear reporting for donors and funding partners.</p>
							<div class="footer-regions">
								{site.regions.map((region) => <span>{region}</span>)}
							</div>
						</section>

						<section class="footer-col">
							<h4>Why Donors Give</h4>
							<ul class="footer-highlights">
								{site.trustPoints.slice(0, 3).map((point) => (
									<li>{point}</li>
								))}
							</ul>
						</section>
					</div>

					<div class="footer-divider"></div>

					<div class="footer-meta-grid footer-meta-grid-bottom">
						<section class="footer-col">
							<h4>Explore</h4>
							<ul class="footer-links-list">
								{site.nav.map((item) => (
									<li><a href={`${base}${item.href}`}>{item.label}</a></li>
								))}
							</ul>
						</section>

						<section class="footer-col">
							<h4>Contact</h4>
							<ul class="footer-contact-list">
								<li><a href={`mailto:${site.contacts.general}`}>{site.contacts.general}</a></li>
								<li><a href={`mailto:${site.contacts.partnerships}`}>{site.contacts.partnerships}</a></li>
								<li><a href={`tel:${site.contacts.phone.replace(/\s+/g, '')}`}>{site.contacts.phone}</a></li>
								<li>{site.contacts.address}</li>
							</ul>
						</section>
					</div>
				</div>
			</div>

			<div class="footer-bottom">
				<p>&copy; {currentYear} {site.name}. Africa-wide mission, currently operating in DR Congo and South Africa.</p>
				<div class="footer-legal">
					<a href={`${base}/privacy`}>Privacy Policy</a>
					<a href={`${base}/terms`}>Terms of Use</a>
				</div>
			</div>
		</div>
	</footer>
</div>

<script>
	const toggle = document.querySelector('.mobile-toggle');
	const nav = document.querySelector('.nav-links');
	if (toggle && nav) {
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			nav.classList.toggle('open');
		});
	}
</script>

<style>
	/* ─── Design tokens ─── */
	:global(:root) {
		--primary: #173f2d;
		--primary-light: #245640;
		--accent: #d4a437;
		--accent-warm: #a96a22;
		--bg: #fff8ed;
		--bg-dark: #163727;
		--surface: rgba(255, 255, 255, 0.74);
		--surface-glass: rgba(255, 255, 255, 0.82);
		--text: #1f2933;
		--text-light: #52606d;
		--text-inverse: #f7f9f4;
		--border: rgba(43, 107, 75, 0.16);
		--shadow-sm: 0 2px 8px rgba(31, 74, 53, 0.08);
		--shadow-md: 0 12px 30px rgba(31, 74, 53, 0.12);
		--shadow-lg: 0 24px 60px rgba(31, 74, 53, 0.16);
		--radius-sm: 0.5rem;
		--radius-md: 1rem;
		--radius-lg: 1.5rem;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		color: var(--text);
		background: var(--bg);
		line-height: 1.6;
		margin: 0;
	}

	:global(a) {
		color: inherit;
	}

	:global(h1),
	:global(h2),
	:global(h3),
	:global(h4) {
		font-family: 'Playfair Display', Georgia, serif;
		font-weight: 700;
		line-height: 1.15;
		margin: 0;
	}

	:global(.section) {
		position: relative;
		z-index: 1;
		width: min(1200px, calc(100% - 3rem));
		margin: 0 auto;
	}

	:global(.eyebrow) {
		margin: 0 0 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--primary-light);
		font-family: 'Inter', system-ui, sans-serif;
	}

	:global(.section-heading) {
		max-width: 48rem;
		margin-bottom: 2rem;
	}

	:global(.section-heading h1) {
		font-size: clamp(2.4rem, 5vw, 4.2rem);
		margin-bottom: 1rem;
	}

	:global(.section-heading h2) {
		font-size: clamp(1.8rem, 3.5vw, 2.8rem);
	}

	:global(.lede) {
		font-size: 1.1rem;
		line-height: 1.75;
		color: var(--text-light);
		max-width: 64ch;
	}

	:global(.panel) {
		backdrop-filter: blur(16px);
		background: var(--surface-glass);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-md);
		border-radius: var(--radius-lg);
	}

	:global(.button) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		padding: 0.95rem 1.55rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.92rem;
		letter-spacing: 0.01em;
		font-family: 'Inter', system-ui, sans-serif;
		transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease, border-color 0.22s ease, color 0.22s ease;
		cursor: pointer;
		border: 1px solid transparent;
		box-shadow: 0 10px 24px rgba(31, 74, 53, 0.12);
	}

	:global(.button:hover) {
		transform: translateY(-2px);
		box-shadow: 0 14px 28px rgba(31, 74, 53, 0.18);
	}

	:global(.button-primary) {
		background: linear-gradient(135deg, #102b1f 0%, #173f2d 55%, #245640 100%);
		color: #fff;
	}

	:global(.button-primary:hover) {
		background: linear-gradient(135deg, #0d241a 0%, #143728 55%, #1f4b37 100%);
	}

	:global(.button-secondary) {
		background: rgba(23, 63, 45, 0.9);
		border-color: rgba(255, 255, 255, 0.12);
		color: #f7f2e6;
	}

	:global(.button-secondary:hover) {
		background: rgba(18, 48, 35, 0.96);
		border-color: rgba(255, 255, 255, 0.18);
		color: #ffffff;
	}

	/* ─── Shell layout ─── */
	.site-shell {
		position: relative;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background: linear-gradient(180deg, rgba(255, 248, 237, 0.96) 0%, rgba(251, 241, 225, 0.92) 100%);
	}

	/* ─── Header ─── */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0.75rem 0 0.4rem;
		background: linear-gradient(180deg, rgba(255, 248, 237, 0.94) 0%, rgba(255, 248, 237, 0.74) 100%);
		backdrop-filter: blur(12px);
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.95rem 1.15rem;
		position: relative;
		width: calc(100% - 1.5rem);
		border-radius: 1.35rem;
		border: 1px solid rgba(23, 63, 45, 0.12);
		background: linear-gradient(135deg, rgba(255, 251, 246, 0.98) 0%, rgba(243, 249, 239, 0.95) 100%);
		box-shadow: 0 16px 34px rgba(31, 74, 53, 0.12);
	}

	.brand-lockup {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		padding: 0.3rem 0.45rem 0.3rem 0.3rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.68);
	}

	.brand-mark {
		display: block;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-sm);
		object-fit: cover;
		box-shadow: var(--shadow-sm);
	}

	.brand-name {
		font-family: 'Playfair Display', Georgia, serif;
		font-weight: 700;
		font-size: 1.3rem;
		color: var(--primary);
	}

	.mobile-toggle {
		display: none;
		background: linear-gradient(135deg, #143728 0%, #245640 100%);
		border: 1px solid rgba(23, 63, 45, 0.18);
		border-radius: 999px;
		box-shadow: 0 12px 24px rgba(31, 74, 53, 0.16);
		cursor: pointer;
		padding: 0.7rem;
	}

	.hamburger,
	.hamburger::before,
	.hamburger::after {
		display: block;
		width: 1.5rem;
		height: 2px;
		background: #ffffff;
		border-radius: 2px;
		transition: all 0.3s ease;
	}

	.hamburger {
		position: relative;
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.hamburger::before {
		top: -6px;
	}

	.hamburger::after {
		top: 6px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.nav-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		color: #ffffff;
		padding: 0.72rem 1.1rem;
		border-radius: 999px;
		border: 1px solid rgba(49, 112, 82, 0.16);
		background: linear-gradient(135deg, #3f7456 0%, #5a9070 100%);
		box-shadow: 0 10px 22px rgba(58, 122, 89, 0.15);
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.nav-links a:hover {
		color: #ffffff;
		background: linear-gradient(135deg, #264a36 0%, #37634a 100%);
		transform: translateY(-1px);
		box-shadow: 0 14px 28px rgba(31, 74, 53, 0.24);
	}

	.nav-links a.active {
		color: #ffffff;
		font-weight: 600;
		background: linear-gradient(135deg, #315f47 0%, #47795d 100%);
		box-shadow: 0 0 0 3px rgba(212, 164, 55, 0.18), 0 14px 28px rgba(58, 122, 89, 0.16);
	}

	.nav-cta {
		background: linear-gradient(135deg, #ef8a1f 0%, #f4b63a 45%, #53a15f 100%) !important;
		color: #fff !important;
		font-weight: 700 !important;
		padding: 0.6rem 1.25rem !important;
		margin-left: 0.5rem;
		box-shadow: 0 14px 28px rgba(211, 137, 28, 0.26);
	}

	.nav-cta:hover {
		background: linear-gradient(135deg, #99520b 0%, #c47f17 45%, #2f6b3a 100%) !important;
		box-shadow: 0 16px 30px rgba(113, 69, 13, 0.3);
	}

	/* ─── Footer ─── */
	.site-footer {
		background:
			linear-gradient(180deg, rgba(31, 74, 53, 0.96) 0%, rgba(21, 56, 40, 1) 100%),
			radial-gradient(circle at top right, rgba(244, 185, 66, 0.16), transparent 32%);
		color: var(--text-inverse);
		margin-top: auto;
		padding: 2rem 0 0;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 0.92fr 1.08fr;
		gap: 1.5rem;
		align-items: start;
		padding-bottom: 1.6rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
	}

	.footer-panel {
		padding: 1.15rem 1.1rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.1rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}

	.footer-kicker {
		margin: 0 0 0.55rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(244, 185, 66, 0.92);
	}

	.footer-brand .brand-mark {
		box-shadow: none;
	}

	.footer-brand .brand-name {
		color: #fff;
	}

	.footer-mission {
		margin: 0.75rem 0 0;
		font-size: 0.92rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.55;
		max-width: 30ch;
	}

	.footer-copy {
		margin: 0.65rem 0 0;
		font-size: 0.88rem;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.72);
	}

	.footer-details {
		display: grid;
		gap: 1rem;
	}

	.footer-meta-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
		align-items: start;
	}

	.footer-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.1);
	}

	.footer-presence {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.9rem;
	}

	.footer-presence span {
		padding: 0.28rem 0.65rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.1);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.88);
	}

	.footer-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: 1rem;
	}

	.footer-button {
		min-width: 8.5rem;
		padding: 0.7rem 1rem;
		font-size: 0.84rem;
	}

	.footer-button-secondary {
		background: rgba(10, 24, 18, 0.3);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.28);
		box-shadow: none;
	}

	.footer-button-secondary:hover {
		background: rgba(10, 24, 18, 0.48);
		color: #fff;
	}

	.footer-col h4 {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.78rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 0.7rem;
		color: rgba(255, 255, 255, 0.5);
	}

	.footer-col h4 + h4 {
		margin-top: 1.15rem;
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: 0.45rem;
		font-size: 0.84rem;
		color: rgba(255, 255, 255, 0.75);
		line-height: 1.45;
	}

	.footer-highlights li {
		position: relative;
		padding-left: 1rem;
	}

	.footer-highlights li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.45rem;
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 0 4px rgba(244, 185, 66, 0.12);
	}

	.footer-links-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		column-gap: 0.9rem;
		row-gap: 0.2rem;
	}

	.footer-regions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.75rem;
	}

	.footer-regions span {
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		background: rgba(244, 185, 66, 0.14);
		border: 1px solid rgba(244, 185, 66, 0.22);
		font-size: 0.74rem;
		font-weight: 600;
		color: #fff7df;
	}

	.footer-highlights li,
	.footer-contact-list li {
		margin-bottom: 0.55rem;
	}

	.footer-col a {
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.footer-col a:hover {
		color: var(--accent);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.15rem 0;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.45);
	}

	.footer-bottom p {
		margin: 0;
	}

	.footer-legal {
		display: flex;
		gap: 1.5rem;
	}

	.footer-legal a {
		text-decoration: none;
		color: rgba(255, 255, 255, 0.45);
		transition: color 0.2s ease;
	}

	.footer-legal a:hover {
		color: rgba(255, 255, 255, 0.8);
	}

	/* ─── Responsive ─── */
	@media (max-width: 900px) {
		.mobile-toggle {
			display: block;
			position: relative;
			z-index: 220;
		}

		.nav-links {
			display: flex;
			position: fixed;
			top: 5.4rem;
			left: 0.75rem;
			right: 0.75rem;
			max-height: calc(100vh - 6.2rem);
			overflow-y: auto;
			flex-direction: column;
			z-index: 260;
			background: rgba(255, 250, 244, 0.98);
			backdrop-filter: blur(18px);
			border: 1px solid rgba(23, 63, 45, 0.1);
			border-radius: 1.25rem;
			box-shadow: 0 20px 48px rgba(31, 74, 53, 0.16);
			padding: 0.85rem;
			gap: 0.55rem;
			opacity: 0;
			visibility: hidden;
			transform: translateY(-0.6rem);
			pointer-events: none;
			transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
		}

		.nav-links.open {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
			pointer-events: auto;
		}

		.nav-links a {
			display: flex;
			align-items: center;
			justify-content: flex-start;
			min-height: 3rem;
			padding: 0.9rem 1rem;
			width: 100%;
			background: linear-gradient(135deg, #3f7456 0%, #5a9070 100%);
			border: 1px solid rgba(49, 112, 82, 0.16);
			border-radius: 0.95rem;
			box-shadow: 0 10px 22px rgba(58, 122, 89, 0.15);
			color: #ffffff;
			position: relative;
			z-index: 1;
			pointer-events: auto;
			touch-action: manipulation;
			-webkit-tap-highlight-color: transparent;
		}

		.nav-links a.active {
			background: linear-gradient(135deg, #315f47 0%, #47795d 100%);
			border-color: rgba(212, 164, 55, 0.28);
		}

		.nav-links a:hover,
		.nav-links a:focus-visible {
			background: linear-gradient(135deg, #264a36 0%, #37634a 100%);
			color: #ffffff;
		}

		.nav-cta {
			margin-left: 0 !important;
			margin-top: 0.35rem;
			text-align: center;
			justify-content: center !important;
			color: #fff !important;
			border: none !important;
			box-shadow: 0 12px 24px rgba(31, 74, 53, 0.22) !important;
		}

		body:has(.nav-links.open) {
			overflow: hidden;
		}

		.footer-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.footer-meta-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.footer-panel {
			padding: 1rem;
		}
	}

	@media (max-width: 600px) {
		:global(.section) {
			width: min(100% - 1.5rem, 1200px);
		}

		.footer-grid {
			grid-template-columns: 1fr;
		}

		.footer-links-list {
			grid-template-columns: 1fr;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.75rem;
			text-align: center;
		}
	}

</style>