---
import IndustrialMotionBackground from './IndustrialMotionBackground.astro';
import { site } from '../data/site';

interface Props {
	activePath?: string;
}

const { activePath = '/' } = Astro.props;
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="site-shell">
	<IndustrialMotionBackground />
	<header class="site-header">
		<div class="header-inner section">
			<a class="brand-lockup" href={`${base}/`} aria-label={site.name}>
				<img class="brand-logo" src={`${base}/favicon.png`} alt={site.name} loading="eager" decoding="async" />
			</a>

			<button class="mobile-toggle" aria-label="Toggle navigation" aria-expanded="false">
				<span class="hamburger"></span>
			</button>

			<nav class="nav-links" aria-label="Primary">
				{site.nav.map((item) => (
					<a class={item.href === activePath ? 'active' : undefined} href={`${base}${item.href}`}>
						{item.label}
					</a>
				))}
			</nav>
		</div>
	</header>

	<slot />

	<footer class="site-footer">
		<div class="footer-inner section">
			<div class="footer-grid">
				<div class="footer-brand">
					<a class="brand-lockup footer-brand-lockup" href={`${base}/`} aria-label={site.name}>
						<img class="brand-logo" src={`${base}/favicon.png`} alt={site.name} loading="lazy" decoding="async" />
					</a>
					<p class="footer-mission">{site.subheadline}</p>
				</div>

				<div class="footer-col">
					<h4>Quick Links</h4>
					<ul>
						{site.nav.map((item) => (
							<li><a href={`${base}${item.href}`}>{item.label}</a></li>
						))}
					</ul>
				</div>

				<div class="footer-col">
					<h4>Core Values</h4>
					<ul>
						{site.values.map((v) => (
							<li>{v.title}</li>
						))}
					</ul>
				</div>

				<div class="footer-col">
					<h4>Contact</h4>
					<ul>
						<li><a href={`mailto:${site.contacts.email}`}>{site.contacts.email}</a></li>
						{site.contacts.phones.map((phone) => (
							<li>{phone}</li>
						))}
						<li>{site.contacts.address}</li>
					</ul>
				</div>
			</div>

			<div class="footer-bottom">
				<p>&copy; {currentYear} {site.name}. All rights reserved. | RCCM: {site.contacts.rccm}</p>
				<div class="footer-legal">
					<span>ID NAT: {site.contacts.idNat}</span>
					<span>ARSP: {site.contacts.arsp}</span>
				</div>
			</div>
		</div>
	</footer>
</div>

<script>
	const toggle = document.querySelector('.mobile-toggle');
	const nav = document.querySelector('.nav-links');
	if (toggle && nav) {
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			nav.classList.toggle('open');
		});
	}
</script>

<style>
	:global(:root) {
		--bg: #0f1113;
		--surface: #171a1e;
		--surface-soft: #1f2429;
		--border: #2a3138;
		--text: #f8f5ef;
		--muted: #c7b9a4;
		--accent: #e25a00;
		--accent-soft: #f08a2a;
		--max: 1160px;
		--radius-sm: 0.7rem;
		--radius-md: 1rem;
		--radius-lg: 1.4rem;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		color: var(--text);
		background:
			radial-gradient(circle at 85% -10%, rgba(255, 106, 0, 0.2), transparent 36%),
			radial-gradient(circle at 5% 20%, rgba(255, 157, 58, 0.14), transparent 36%),
			var(--bg);
		line-height: 1.6;
		margin: 0;
	}

	:global(a) {
		color: inherit;
	}

	:global(h1),
	:global(h2),
	:global(h3),
	:global(h4) {
		font-family: 'Playfair Display', Georgia, serif;
		font-weight: 700;
		line-height: 1.15;
		margin: 0;
	}

	:global(.section) {
		width: min(var(--max), calc(100% - 3rem));
		margin: 0 auto;
	}

	:global(.panel) {
		background: linear-gradient(180deg, var(--surface) 0%, #13161a 100%);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
	}

	:global(.section-heading) {
		max-width: 48rem;
		margin-bottom: 2rem;
	}

	:global(.section-heading h1) {
		font-size: clamp(2.4rem, 5vw, 4.2rem);
		margin-bottom: 1rem;
	}

	:global(.section-heading h2) {
		font-size: clamp(1.8rem, 3.5vw, 2.8rem);
	}

	:global(.lede) {
		font-size: 1.1rem;
		line-height: 1.75;
		color: var(--text-light);
		max-width: 64ch;
	}

	:global(.panel) {
		backdrop-filter: blur(16px);
		background: var(--surface-glass);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-md);
		border-radius: var(--radius-lg);
	}

	:global(.button) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.75rem;
		border-radius: var(--radius-sm);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		font-family: 'Inter', system-ui, sans-serif;
		transition: all 0.25s ease;
		cursor: pointer;
	}

	:global(.button:hover) {
		transform: translateY(-1px);
		box-shadow: var(--shadow-sm);
	}

	:global(.button-primary) {
		background: var(--primary);
		color: #fff;
	}

	:global(.button-primary:hover) {
		background: var(--primary-light);
	}

	:global(.button-secondary) {
		background: transparent;
		border: 2px solid var(--primary);
		color: var(--primary);
	}

	:global(.button-secondary:hover) {
		background: var(--primary);
		color: #fff;
	}

	.site-shell {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		position: relative;
		isolation: isolate;
	}

	.site-shell > :global(.industrial-bg) {
		z-index: 0;
	}

	.site-shell > :not(:global(.industrial-bg)) {
		position: relative;
		z-index: 1;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		background: rgba(15, 17, 19, 0.88);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.7rem;
		padding: 0.52rem 0;
	}

	.brand-lockup {
		display: flex;
		align-items: center;
		text-decoration: none;
	}

	.brand-logo {
		width: clamp(150px, 18vw, 250px);
		height: auto;
		max-height: 56px;
		object-fit: contain;
	}

	.brand-copy {
		display: none;
	}

	.brand-copy strong {
		font-size: 0.92rem;
		letter-spacing: 0.04em;
		color: var(--text);
	}

	.brand-copy span {
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.mobile-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
	}

	.hamburger,
	.hamburger::before,
	.hamburger::after {
		display: block;
		width: 1.5rem;
		height: 2px;
		background: var(--text);
		border-radius: 2px;
		transition: all 0.3s ease;
	}

	.hamburger {
		position: relative;
	}

	.hamburger::before,
	.hamburger::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.hamburger::before {
		top: -6px;
	}

	.hamburger::after {
		top: 6px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.2rem;
	}

	.nav-links a {
		text-decoration: none;
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--muted);
		padding: 0.36rem 0.62rem;
		border-radius: var(--radius-sm);
		transition: all 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--text);
		background: rgba(255, 106, 0, 0.1);
	}

	.nav-links a.active {
		color: #fff;
		font-weight: 600;
		background: linear-gradient(135deg, var(--accent), var(--accent-soft));
	}

	.site-footer {
		background: #101316;
		margin-top: auto;
		border-top: 1px solid var(--border);
		padding: 2.1rem 0 0;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1.5fr;
		gap: 1.4rem;
		padding-bottom: 1.35rem;
		border-bottom: 1px solid var(--border);
	}

	.footer-brand-lockup {
		align-items: flex-start;
	}

	.footer-brand .brand-logo {
		width: clamp(112px, 14vw, 170px);
	}

	.footer-mission {
		margin: 0.7rem 0 0;
		font-size: 0.84rem;
		color: #b9a993;
		line-height: 1.5;
		max-width: 33ch;
	}

	.footer-col h4 {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.74rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 0.7rem;
		color: #9b8a74;
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: 0.4rem;
		font-size: 0.82rem;
		color: #d9d1c8;
		line-height: 1.45;
	}

	.footer-col a {
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.footer-col a:hover {
		color: var(--accent);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.9rem 0 1.1rem;
		font-size: 0.76rem;
		color: #a79279;
	}

	.footer-bottom p {
		margin: 0;
	}

	.footer-legal {
		display: flex;
		gap: 1rem;
	}

	@media (max-width: 900px) {
		.mobile-toggle {
			display: block;
		}

		.nav-links {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			background: rgba(16, 19, 22, 0.96);
			backdrop-filter: blur(8px);
			border-bottom: 1px solid var(--border);
			padding: 1rem;
			gap: 0;
		}

		.nav-links.open {
			display: flex;
		}

		.nav-links a {
			padding: 0.75rem 1rem;
			width: 100%;
		}

		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.footer-brand {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 600px) {
		:global(.section) {
			width: min(100% - 1.5rem, var(--max));
		}

		.brand-logo,
		.footer-brand .brand-logo {
			width: min(160px, 52vw);
		}

		.footer-grid {
			grid-template-columns: 1fr;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.75rem;
			text-align: center;
		}
	}

</style>