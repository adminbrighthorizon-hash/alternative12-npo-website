---
import SiteShell from './SiteShell.astro';
import { site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<SiteShell activePath="/">
	<main>
		<!-- Hero with full-bleed background image -->
		<section class="hero">
			<div class="hero-bg">
				<img src={site.heroImage} alt="African children in a community setting" />
				<div class="hero-overlay"></div>
			</div>
			<div class="hero-content section">
				<p class="hero-eyebrow">{site.tagline}</p>
				<h1>{site.headline}</h1>
				<p class="hero-sub">{site.subheadline}</p>
				<div class="hero-actions">
					<a class="button button-primary hero-btn" href={`${base}/donate`}>Donate Now</a>
					<a class="button button-secondary hero-btn-outline" href={`${base}/about`}>Learn More</a>
				</div>
			</div>
		</section>

		<!-- Announcement banner -->
		<section class="banner-strip">
			<div class="section">
				<div class="banner-frame">
					<span class="banner-label">Donor Impact</span>
					<div class="banner-marquee">
						<p class="banner-message">{site.banner}</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Stats bar -->
		<section class="stats-bar">
			<div class="stats-inner section">
				{site.stats.map((stat) => (
					<div class="stat-item">
						<strong>{stat.value}</strong>
						<span>{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<!-- Mission / About preview -->
		<section class="mission-section">
			<div class="mission-inner section">
				<div class="mission-text">
					<p class="eyebrow">Our Mission</p>
					<h2>Locally led development that transforms lives.</h2>
					<p class="lede">{site.mission}</p>
					<a class="button button-secondary" href={`${base}/about`}>About Our Approach</a>
				</div>
				<div class="mission-image">
					<img src={site.gallery[0].src} alt={site.gallery[0].alt} loading="lazy" decoding="async" />
				</div>
			</div>
		</section>

		<!-- Who We Serve -->
		<section class="audience-section">
			<div class="section">
				<div class="section-heading">
					<p class="eyebrow">Who We Serve</p>
					<h2>Trusted by communities, partners, and donors alike.</h2>
				</div>
				<div class="audience-grid">
					{site.audiences.map((audience) => (
						<article class="audience-card">
							<h3>{audience.title}</h3>
							<p>{audience.description}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Programs -->
		<section class="programs-section">
			<div class="section">
				<div class="section-heading">
					<p class="eyebrow">Our Programs</p>
					<h2>Addressing everyday challenges faced by kids, people with disabilities, and mothers surviving abuse.</h2>
				</div>
				<div class="program-grid">
					{site.programs.map((program) => (
						<article class="program-card">
							<div class="program-img">
								<img src={program.image} alt={program.title} loading="lazy" decoding="async" />
							</div>
							<div class="program-body">
								<span class="program-id">{program.id}</span>
								<h3>{program.title}</h3>
								<p>{program.description}</p>
							</div>
						</article>
					))}
				</div>
				<div class="programs-cta">
					<a class="button button-primary" href={`${base}/programs`}>View All Programs</a>
				</div>
			</div>
		</section>

		<!-- Gallery -->
		<section class="gallery-section">
			<div class="section">
				<div class="section-heading">
					<p class="eyebrow">Our Work in Action</p>
					<h2>Real communities, real impact.</h2>
				</div>
				<div class="gallery-grid">
					{site.gallery.map((item, index) => (
						<figure class={`gallery-item ${index === 0 ? 'gallery-wide' : ''}`}>
							<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
							<figcaption>
								<strong>{item.title}</strong>
								<span>{item.description}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- Impact -->
		<section class="impact-section">
			<div class="section">
				<div class="impact-layout">
					<div class="impact-content">
						<p class="eyebrow">Impact Snapshot</p>
						<h2>Measurable results from the past 12 months.</h2>
						<ul class="impact-list">
							{site.impact.map((item) => {
								const [lead, ...rest] = item.split(' ');
								return <li><strong>{lead}</strong> {rest.join(' ')}</li>;
							})}
						</ul>
					</div>
					<div class="impact-regions">
						<h3>Where We Work</h3>
						<p>Active programs across six African nations with deep local partnerships.</p>
						<div class="region-chips">
							{site.regions.map((region) => <span>{region}</span>)}
						</div>
						<img src={site.gallery[5].src} alt={site.gallery[5].alt} class="regions-photo" loading="lazy" decoding="async" />
					</div>
				</div>
			</div>
		</section>

		<!-- Stories -->
		<section class="stories-section">
			<div class="section">
				<div class="section-heading">
					<p class="eyebrow">From the Field</p>
					<h2>Stories of change from across the continent.</h2>
				</div>
				<div class="story-grid">
					{site.stories.map((story) => (
						<article class="story-card">
							<div class="story-img">
								<img src={story.image} alt={story.title} loading="lazy" decoding="async" />
							</div>
							<div class="story-body">
								<span class="story-tag">{story.place}</span>
								<h3>{story.title}</h3>
								<p>{story.description}</p>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- CTA / Get Involved -->
		<section class="cta-section">
			<div class="cta-inner section">
				<div class="cta-content">
					<p class="eyebrow">Get Involved</p>
					<h2>Join us in building stronger futures for African communities.</h2>
					<p>Whether you are a donor, partner, or volunteer, there is a place for you in this work. Together we can reach more children, strengthen more families, and create lasting change.</p>
				</div>
				<div class="cta-actions">
					<a class="button button-primary" href={`${base}/donate`}>Make a Donation</a>
					<a class="button button-secondary" href={`mailto:${site.contacts.partnerships}`}>Partner With Us</a>
					<a class="button button-secondary" href={`${base}/contact`}>Contact Us</a>
				</div>
			</div>
		</section>
	</main>
</SiteShell>

<style>
	/* ─── Hero ─── */
	.hero {
		position: relative;
		min-height: 85vh;
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
	}

	.hero-bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to right,
			rgba(31, 74, 53, 0.88) 0%,
			rgba(31, 74, 53, 0.65) 50%,
			rgba(31, 74, 53, 0.3) 100%
		);
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding: 6rem 0;
		max-width: 640px;
		color: #fff;
	}

	.hero-eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.85rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.75);
		margin: 0 0 1rem;
	}

	.hero-content h1 {
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.1;
		margin-bottom: 1.25rem;
		color: #fff;
	}

	.hero-sub {
		font-size: 1.15rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.85);
		margin: 0 0 2rem;
		max-width: 50ch;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.hero-btn {
		background: #fff !important;
		color: var(--primary) !important;
		font-weight: 700 !important;
		padding: 1rem 2rem !important;
	}

	.hero-btn:hover {
		background: var(--accent) !important;
		color: #fff !important;
	}

	.hero-btn-outline {
		border-color: rgba(255, 255, 255, 0.5) !important;
		color: #fff !important;
		padding: 1rem 2rem !important;
	}

	.hero-btn-outline:hover {
		background: rgba(255, 255, 255, 0.15) !important;
	}

	/* ─── Banner ─── */
	.banner-strip {
		background: linear-gradient(135deg, rgba(242, 248, 239, 0.98) 0%, rgba(255, 246, 231, 0.98) 55%, rgba(249, 239, 214, 0.98) 100%);
		color: var(--primary);
		padding: 1.1rem 0;
		overflow: hidden;
		border-top: 1px solid rgba(36, 86, 64, 0.08);
		border-bottom: 1px solid rgba(212, 164, 55, 0.18);
	}

	.banner-frame {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 0.9rem;
		padding: 0.55rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.52);
		border: 1px solid rgba(36, 86, 64, 0.1);
		box-shadow: 0 12px 30px rgba(24, 66, 47, 0.08);
		backdrop-filter: blur(10px);
	}

	.banner-label {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.82rem 1rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #1d4b35 0%, #2b6b4b 100%);
		color: #f8fbf5;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		white-space: nowrap;
		box-shadow: 0 12px 22px rgba(29, 75, 53, 0.18);
	}

	.banner-marquee {
		overflow: hidden;
		position: relative;
		min-height: 3.35rem;
		display: flex;
		align-items: center;
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 251, 242, 0.94) 100%);
		border: 1px solid rgba(212, 164, 55, 0.18);
		padding-inline: 1rem;
	}

	.banner-marquee::before,
	.banner-marquee::after {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		width: 3rem;
		pointer-events: none;
		z-index: 2;
	}

	.banner-marquee::before {
		left: 0;
		background: linear-gradient(90deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0) 100%);
	}

	.banner-marquee::after {
		right: 0;
		background: linear-gradient(270deg, rgba(255, 251, 242, 0.98) 0%, rgba(255, 251, 242, 0) 100%);
	}

	.banner-message {
		position: absolute;
		left: 0;
		display: inline-flex;
		align-items: center;
		padding: 0.82rem 1.35rem;
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.97) 0%, rgba(255, 249, 236, 0.96) 100%);
		border: 1px solid rgba(212, 164, 55, 0.28);
		box-shadow: 0 14px 28px rgba(33, 78, 56, 0.12);
		color: #1d4b35;
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.65);
		animation: banner-glide 28s linear 2.4s infinite;
		will-change: transform;
	}

	.banner-strip p {
		margin: 0;
		font-weight: 700;
		font-size: 0.95rem;
		letter-spacing: 0.012em;
		line-height: 1.45;
		white-space: nowrap;
	}

	@keyframes banner-glide {
		0%, 12% {
			transform: translateX(calc(100% + 2rem));
		}

		100% {
			transform: translateX(calc(-100% - 2rem));
		}
	}

	/* ─── Stats ─── */
	.stats-bar {
		background: var(--surface);
		border-bottom: 1px solid var(--border);
		padding: 2.5rem 0;
	}

	.stats-inner {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		text-align: center;
	}

	.stat-item strong {
		display: block;
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 2.2rem;
		color: var(--primary);
		margin-bottom: 0.3rem;
	}

	.stat-item span {
		font-size: 0.9rem;
		color: var(--text-light);
	}

	/* ─── Mission ─── */
	.mission-section {
		padding: 5rem 0;
	}

	.mission-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.mission-text h2 {
		font-size: clamp(1.8rem, 3.5vw, 2.6rem);
		margin-bottom: 1.25rem;
	}

	.mission-text .lede {
		margin-bottom: 2rem;
	}

	.mission-image {
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-lg);
	}

	.mission-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		min-height: 400px;
	}

	/* ─── Audience ─── */
	.audience-section {
		padding: 5rem 0;
		background: var(--surface);
	}

	.audience-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.audience-card {
		padding: 2rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--border);
		transition: all 0.25s ease;
	}

	.audience-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.audience-card h3 {
		font-size: 1.35rem;
		margin-bottom: 0.75rem;
		color: var(--primary);
	}

	.audience-card p {
		color: var(--text-light);
		line-height: 1.7;
		margin: 0;
	}

	/* ─── Programs ─── */
	.programs-section {
		padding: 5rem 0;
	}

	.program-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.program-card {
		display: grid;
		grid-template-columns: 200px 1fr;
		border-radius: var(--radius-md);
		overflow: hidden;
		border: 1px solid var(--border);
		background: var(--surface);
		transition: all 0.25s ease;
	}

	.program-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.program-img img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		min-height: 220px;
	}

	.program-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.program-id {
		display: inline-block;
		font-weight: 700;
		font-size: 0.8rem;
		color: var(--primary-light);
		letter-spacing: 0.08em;
		margin-bottom: 0.5rem;
	}

	.program-body h3 {
		font-size: 1.3rem;
		margin-bottom: 0.6rem;
	}

	.program-body p {
		color: var(--text-light);
		line-height: 1.65;
		margin: 0;
		font-size: 0.95rem;
	}

	.programs-cta {
		text-align: center;
		margin-top: 2.5rem;
	}

	/* ─── Gallery ─── */
	.gallery-section {
		padding: 5rem 0;
		background: var(--surface);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.gallery-item {
		margin: 0;
		position: relative;
		border-radius: var(--radius-md);
		overflow: hidden;
		cursor: pointer;
		isolation: isolate;
	}

	.gallery-item::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(8, 18, 13, 0.08) 0%, rgba(8, 18, 13, 0.16) 32%, rgba(8, 18, 13, 0.78) 100%);
		z-index: 1;
		pointer-events: none;
	}

	.gallery-wide {
		grid-column: span 2;
	}

	.gallery-item img {
		display: block;
		width: 100%;
		height: 280px;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.gallery-wide img {
		height: 320px;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.gallery-item figcaption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 2;
		padding: 2.75rem 1.25rem 1.25rem;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(7, 18, 13, 0.18) 28%, rgba(7, 18, 13, 0.82) 100%);
		color: #fff;
		opacity: 1;
		transition: transform 0.3s ease, background 0.3s ease;
	}

	.gallery-item:hover figcaption {
		transform: translateY(-0.15rem);
		background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(7, 18, 13, 0.22) 26%, rgba(7, 18, 13, 0.88) 100%);
	}

	.gallery-item figcaption strong {
		display: block;
		font-size: 1.02rem;
		margin-bottom: 0.3rem;
		text-shadow: 0 2px 14px rgba(0, 0, 0, 0.45);
	}

	.gallery-item figcaption span {
		display: block;
		max-width: 38ch;
		font-size: 0.88rem;
		line-height: 1.5;
		color: rgba(255, 255, 255, 0.94);
		text-shadow: 0 2px 12px rgba(0, 0, 0, 0.42);
	}

	/* ─── Impact ─── */
	.impact-section {
		padding: 5rem 0;
	}

	.impact-layout {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 3rem;
	}

	.impact-content h2 {
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		margin-bottom: 2rem;
	}

	.impact-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1rem;
	}

	.impact-list li {
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--border);
		color: var(--text-light);
		line-height: 1.65;
	}

	.impact-list li:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.impact-list strong {
		color: var(--primary);
		font-size: 1.1rem;
	}

	.impact-regions {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 2rem;
	}

	.impact-regions h3 {
		font-size: 1.4rem;
		margin-bottom: 0.75rem;
	}

	.impact-regions > p {
		color: var(--text-light);
		line-height: 1.65;
		margin: 0 0 1.25rem;
	}

	.region-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.region-chips span {
		padding: 0.4rem 0.85rem;
		border-radius: var(--radius-sm);
		background: rgba(43, 107, 75, 0.12);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--primary);
	}

	.regions-photo {
		width: 100%;
		border-radius: var(--radius-md);
		object-fit: cover;
		height: 180px;
	}

	/* ─── Stories ─── */
	.stories-section {
		padding: 5rem 0;
		background: var(--surface);
	}

	.story-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.story-card {
		border-radius: var(--radius-md);
		background: rgba(43, 107, 75, 0.12);
		border: 1px solid var(--border);
		background: var(--bg);
		transition: all 0.25s ease;
	}

	.story-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-3px);
	}

	.story-img img {
		display: block;
		width: 100%;
		height: 220px;
		object-fit: cover;
	}

	.story-body {
		padding: 1.5rem;
	}

	.story-tag {
		display: inline-block;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--primary-light);
		margin-bottom: 0.5rem;
	}

	.story-body h3 {
		font-size: 1.2rem;
		margin-bottom: 0.6rem;
	}

	.story-body p {
		color: var(--text-light);
		line-height: 1.65;
		font-size: 0.95rem;
		margin: 0;
	}

	/* ─── CTA ─── */
	.cta-section {
		padding: 5rem 0;
	}

	.cta-inner {
		background: var(--primary);
		border-radius: var(--radius-lg);
		padding: 4rem;
		display: grid;
		grid-template-columns: 1.3fr 0.7fr;
		gap: 3rem;
		align-items: center;
		color: #fff;
	}

	.cta-content .eyebrow {
		color: var(--accent);
	}

	.cta-content h2 {
		color: #fff;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		margin-bottom: 1rem;
	}

	.cta-content p {
		color: rgba(255, 255, 255, 0.8);
		line-height: 1.7;
		margin: 0;
	}

	.cta-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.cta-actions .button-primary {
		background: #fff;
		color: var(--primary);
